      "hardness": 2,
      "required_tools": ["axe"],
      "drops": [
        { "item": "wood_log", "min": 1, "max": 3 }
      ],
      "sprite": "assets/images/environment/tree_oak.png",
	  
	  "states": {
	    "normal": "assets/images/environment/tree_oak.png",
	    "cut":    "assets/images/environment/tree_oak_stump.png"
		},
		
	  "footprint": { "w": 1, "h": 2 },
      "spriteSize": { "w": 192, "h": 192 },
      "anchor": "bottom",
      "offset": { "x": -80, "y": 16 },
      "collidable": true,

      "animations": {
        "destroy": {
          "sprite_sheet": "assets/animations/tree_oak_fall.png",
          "frameWidth": 64,
          "frameHeight": 96,
          "frames": 6,
          "duration_ms": 600
        }
      },

      "sounds": {
        "hit": "assets/sfx/wood_hit.wav",
        "destroy": "assets/sfx/tree_fall.wav"
      }
    },
